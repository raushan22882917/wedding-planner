+        };
+      }
+    ).pupPage;
+    if (!page) return [];
+
+    const cached = await page.evaluate(
+      (targetChatId: string, maxMessages: number) => {
+        type ChatRecord = {
+          id?: { _serialized?: unknown };
+          msgs?: { getModelsArray?: () => unknown[] };
+        };
+        type MessageRecord = {
+          id?: { _serialized?: unknown; fromMe?: unknown; remote?: unknown };
+          from?: unknown;
+          to?: unknown;
+          body?: unknown;
+          type?: unknown;
+          timestamp?: unknown;
+          t?: unknown;
+          author?: unknown;
+        };
+        const waWindow = window as unknown as {
+          require?: (moduleName: string) => {
+            Chat?: { getModelsArray?: () => unknown[] };
+            Msg?: { getModelsArray?: () => unknown[] };
+          };
+        };
+        const collections = waWindow.require?.('WAWebCollections');
+        const chats = collections?.Chat?.getModelsArray?.() ?? [];
+        const chat = chats.find(rawChat => (rawChat as ChatRecord).id?._serialized === targetChatId) as
+          ChatRecord | undefined;
