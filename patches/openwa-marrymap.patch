+   */
+  private async getCachedChats(): Promise<ChatSummary[]> {
+    const page = (
+      this.client as unknown as {
+        pupPage?: {
+          evaluate: <T>(fn: () => T) => Promise<T>;
+        };
+      }
+    ).pupPage;
+    if (!page) return [];
+
+    return page.evaluate(() => {
+      type ChatRecord = {
+        id?: { _serialized?: unknown };
+        formattedTitle?: unknown;
+        name?: unknown;
+        groupMetadata?: unknown;
+        unreadCount?: unknown;
+        timestamp?: unknown;
+        t?: unknown;
+        lastReceivedKey?: { _serialized?: unknown };
+        lastMessage?: { body?: unknown; type?: unknown } | null;
+      };
+      const waWindow = window as unknown as {
+        require?: (moduleName: string) => {
+          Chat?: { getModelsArray?: () => unknown[] };
+          Msg?: { get?: (id: string) => { body?: unknown } | undefined };
+        };
+      };
+      const collections = waWindow.require?.('WAWebCollections');
+      const chats = collections?.Chat?.getModelsArray?.() ?? [];
+
+      return chats.flatMap(rawChat => {
+        try {
+          const chat = rawChat as ChatRecord;
+          const id = typeof chat.id?._serialized === 'string' ? chat.id._serialized : null;
+          if (!id) return [];
+          const name =
+            typeof chat.formattedTitle === 'string'
+              ? chat.formattedTitle
+              : typeof chat.name === 'string'
+                ? chat.name
+                : id;
+          const timestamp =
+            typeof chat.timestamp === 'number' ? chat.timestamp : typeof chat.t === 'number' ? chat.t : 0;
+          const cachedLastBody =
+            typeof chat.lastReceivedKey?._serialized === 'string'
+              ? collections?.Msg?.get?.(chat.lastReceivedKey._serialized)?.body
+              : undefined;
+          return [
+            {
+              id,
+              name,
+              isGroup: Boolean(chat.groupMetadata),
+              unreadCount: typeof chat.unreadCount === 'number' ? chat.unreadCount : 0,
+              timestamp,
+              lastMessage:
+                typeof chat.lastMessage?.body === 'string'
+                  ? chat.lastMessage.body
+                  : typeof cachedLastBody === 'string'
+                    ? cachedLastBody
+                    : undefined,
+            },
+          ];
+        } catch {
+          return [];
+        }
+      });
+    });
+  }
