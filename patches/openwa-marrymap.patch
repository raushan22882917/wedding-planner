+            if (!id) return [];
+            return [
+              {
+                id,
+                from: typeof message.from === 'string' ? message.from : targetChatId,
+                to: typeof message.to === 'string' ? message.to : targetChatId,
+                body: typeof message.body === 'string' ? message.body : '',
