# ==============================================================================
# MarryMap Unified Environment Configuration
# ==============================================================================
# Copy this file to `.env` in the root of the repository.
# Both frontend (apps/web) and backend (apps/api) are configured to load from here.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Supabase Settings (Shared by Web & API)
# ------------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
# service_role key must NEVER be prefixed with VITE_ or exposed to the client
SUPABASE_SERVICE_ROLE_KEY=replace-me-with-service-role-key

# ------------------------------------------------------------------------------
# 2. Frontend Client (Web) Settings
# ------------------------------------------------------------------------------
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# Client-exposed variables (VITE_ prefixed)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# Search Backend Server URL (Web frontend uses this to speak to the API)
SEARCH_BACKEND_URL=http://localhost:3000

# Gemini AI chat (server-only — do not prefix this variable with VITE_)
GEMINI_API_KEY=
# Optional: override the default `gemini-3.5-flash` model.
# GEMINI_MODEL=gemini-3.5-flash

# Razorpay Payment Links (server-only)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Web Agent Reach Configuration
AGENT_REACH_MCPORTER_CONFIG=../../config/mcporter.json
AGENT_REACH_MCPORTER_BIN=mcporter
AGENT_REACH_YTDLP_BIN=yt-dlp
AGENT_REACH_SOCIAL_ENABLED=true
AGENT_REACH_OPENCLI_BIN=opencli
AGENT_REACH_TWITTER_BIN=twitter

# ------------------------------------------------------------------------------
# 3. Backend (API) Settings
# ------------------------------------------------------------------------------
# API Host and Port
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# CORS setup (Allow frontend dev server URL)
CORS_ORIGINS=http://localhost:5173

# API Auth Guard (set true in production)
SUPABASE_AUTH_REQUIRED=true
DEMO_OWNER_ID=00000000-0000-0000-0000-000000000001

# Scraper capacity
SCRAPER_ALLOWED_HOSTS=
SCRAPER_TIMEOUT_MS=20000
SCRAPER_MAX_RESPONSE_BYTES=2000000
SCRAPER_MAX_ITEMS_PER_RUN=25
RUN_WORKER=true
WORKER_POLL_MS=2000

# API Agent Reach-compatible providers
JINA_READER_BASE_URL=https://r.jina.ai
EXA_PROVIDER=mcporter
EXA_API_KEY=
MCPORTER_BIN=mcporter
MCPORTER_CONFIG=../../config/mcporter.json
AGENT_REACH_SOCIAL_ENABLED=false
AGENT_REACH_OPENCLI_BIN=opencli
AGENT_REACH_TWITTER_BIN=twitter

# WhatsApp Gateway Settings
OPENWA_USE_LOCAL_GATEWAY=true
# For remote or production gateway:
# OPENWA_BASE_URL=https://openwa.example.com
# OPENWA_API_KEY=your-private-openwa-operator-key

# Dograh voice-agent integration
# DOGRAH_TRIGGER_URL=https://your-dograh-instance/api/v1/public/agent/your-trigger-uuid
# DOGRAH_RUNS_BASE_URL=https://your-dograh-instance
# DOGRAH_API_KEY=dg_your_private_key
# DOGRAH_WORKFLOW_ID=123
# DOGRAH_TELEPHONY_CONFIGURATION_ID=1
