# Required: Supabase project settings (use the service role only on the server).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me

# HTTP server
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173

# Set true in production. Requests then require a valid Supabase access token.
SUPABASE_AUTH_REQUIRED=true
# Used only for local development when SUPABASE_AUTH_REQUIRED=false.
DEMO_OWNER_ID=00000000-0000-0000-0000-000000000001

# Scraper safety / capacity
SCRAPER_ALLOWED_HOSTS=
SCRAPER_TIMEOUT_MS=20000
SCRAPER_MAX_RESPONSE_BYTES=2000000
SCRAPER_MAX_ITEMS_PER_RUN=25
RUN_WORKER=true
WORKER_POLL_MS=2000

# Agent Reach-compatible providers
# Jina Reader is Agent Reach's standard public-page reader.
JINA_READER_BASE_URL=https://r.jina.ai
# Enable semantic web search only when one provider is configured.
# EXA_PROVIDER=api needs EXA_API_KEY. EXA_PROVIDER=mcporter calls the local
# Agent Reach mcporter route (no shell interpolation; see README).
EXA_PROVIDER=mcporter
EXA_API_KEY=
MCPORTER_BIN=mcporter
# Path is resolved from the API process working directory.
MCPORTER_CONFIG=../../config/mcporter.json

# Optional local social discovery. Agent Reach uses X via twitter-cli and
# Reddit, Facebook, Instagram, and Xiaohongshu via the signed-in OpenCLI browser.
AGENT_REACH_SOCIAL_ENABLED=false
AGENT_REACH_OPENCLI_BIN=opencli
AGENT_REACH_TWITTER_BIN=twitter

# In development, MarryMap uses the checked-in apps/openwa source automatically.
# Start it from the repository root: npm run whatsapp:gateway
OPENWA_USE_LOCAL_GATEWAY=true
# For a remote or production gateway, set both private server-only values and
# set OPENWA_USE_LOCAL_GATEWAY=false.
# OPENWA_BASE_URL=https://openwa.example.com
# OPENWA_API_KEY=your-private-openwa-operator-key

# Optional Dograh voice-agent integration for consented vendor availability calls.
# Use a published Dograh API Trigger URL and keep every value on this server.
# DOGRAH_TRIGGER_URL=https://your-dograh-instance/api/v1/public/agent/your-trigger-uuid
# DOGRAH_RUNS_BASE_URL=https://your-dograh-instance
# DOGRAH_API_KEY=dg_your_private_key
# DOGRAH_WORKFLOW_ID=123
# Optional: choose a specific configured Dograh telephony number/provider.
# DOGRAH_TELEPHONY_CONFIGURATION_ID=1
