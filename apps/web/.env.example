# Supabase
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Gemini AI chat (server-only — do not prefix this variable with VITE_)
GEMINI_API_KEY=
# AI_API_KEY is also accepted for existing deployments that use this name.
# AI_API_KEY=
# Optional: override the default `gemini-3.5-flash` model.
# GEMINI_MODEL=gemini-3.5-flash

# Razorpay Payment Links (server-only). Register the HTTPS webhook endpoint
# https://<your-domain>/api/billing/razorpay for payment_link.paid and copy
# the webhook signing secret below. The app verifies both that signature and
# the payment amount against its server-side checkout record before granting
# a plan or usage pack.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Required by secure checkout creation and the verified webhook; never expose
# this value with a VITE_ prefix or in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Private search backend. It must use the same Supabase project as this app so
# the signed-in user's bearer token can securely scope search results.
SEARCH_BACKEND_URL=http://localhost:3000
# Server-only fallback for live public sources when the database worker is unavailable.
AGENT_REACH_MCPORTER_CONFIG=../../config/mcporter.json
AGENT_REACH_MCPORTER_BIN=mcporter
AGENT_REACH_YTDLP_BIN=yt-dlp
AGENT_REACH_SOCIAL_ENABLED=true
AGENT_REACH_OPENCLI_BIN=opencli
AGENT_REACH_TWITTER_BIN=twitter
